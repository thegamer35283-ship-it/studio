
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a robust, database-backed access control (DBAC) model.
     * Privileges are determined by the existence of a document in the /admins/ collection.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /donors/{donorId} {
      allow get: if isOwner(donorId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(donorId);
      allow update: if isOwner(donorId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /donation_tiers/{tierId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    match /donations/{donationId} {
      // Allow creation for anyone to support guest donations, 
      // but only allow read/list for admins or the specific owner.
      allow create: if true; 
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.donorId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read, write: if isAdmin();
    }

    match /beneficiary_communities/{communityId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /transparency_reports/{reportId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /donation_tiers/{tierId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow users to register themselves as admins for prototype purposes
      allow create: if isOwner(uid);
      allow update, delete: if isAdmin();
    }
  }
}
